<Window x:Class="himchistka.practic.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="420"
        Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#FFF5F7FA">
    <Grid Margin="24">
        <Border Background="White" CornerRadius="14" Padding="24">
            <StackPanel>
                <TextBlock Text="Авторизация"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0 0 0 18"/>

                <TextBlock Text="Логин"/>
                <TextBox x:Name="LoginTextBox" Height="36" Margin="0 6 0 12" VerticalContentAlignment="Center"/>

                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="PasswordBox" Height="36" Margin="0 6 0 18"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Назад" Width="120" Height="38" Margin="0 0 10 0" Click="BackButton_Click"/>
                    <Button Content="Войти" Width="120" Height="38" Click="SignInButton_Click"/>
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock" Margin="0 12 0 0" TextWrapping="Wrap" Foreground="DarkRed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
