<Window x:Class="himchistka.practic.Views.OrderQrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR заказа"
        Height="420"
        Width="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Отсканируйте QR для деталей заказа"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"
                   TextAlignment="Center" />

        <Border Grid.Row="1"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="8"
                CornerRadius="8">
            <Image x:Name="QrImage"
                   Stretch="Uniform" />
        </Border>

        <Button Grid.Row="2"
                Content="Закрыть"
                Width="100"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                IsDefault="True"
                Click="CloseButton_Click" />
    </Grid>
</Window>
