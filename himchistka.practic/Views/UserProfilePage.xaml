<Page x:Class="himchistka.practic.Views.UserProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UserProfilePage">
    <Grid Margin="20" Background="#F4F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button Content="Назад" Command="{Binding BackCommand}" Padding="14,6" Background="#1F3A5F" Foreground="White" BorderThickness="0"/>
            <TextBlock Text="Информация о пользователе" FontSize="24" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#1F3A5F"/>
        </DockPanel>

        <Border Grid.Row="1" Background="White" Padding="20" CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="ФИО" FontWeight="Bold" Foreground="#1F3A5F"/>
                <TextBlock Text="{Binding FullName}" Margin="0,2,0,10" FontSize="15"/>

                <TextBlock Text="Email" FontWeight="Bold" Foreground="#1F3A5F"/>
                <TextBlock Text="{Binding Email}" Margin="0,2,0,10" FontSize="15"/>

                <TextBlock Text="Телефон" FontWeight="Bold" Foreground="#1F3A5F"/>
                <TextBlock Text="{Binding Phone}" Margin="0,2,0,10" FontSize="15"/>

                <TextBlock Text="Роль" FontWeight="Bold" Foreground="#1F3A5F"/>
                <TextBlock Text="{Binding RoleName}" Margin="0,2,0,10" FontSize="15"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
