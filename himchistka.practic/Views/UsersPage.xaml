<Page x:Class="himchistka.practic.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UsersPage">
    <Grid Margin="20" Background="#F4F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button Content="Назад" Command="{Binding BackCommand}" Padding="14,6" Background="#1F3A5F" Foreground="White" BorderThickness="0"/>
            <TextBlock Text="Страница пользователей" FontSize="24" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#1F3A5F"/>
        </DockPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" AutoGenerateColumns="False" RowBackground="White" AlternatingRowBackground="#F9FBFF" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="220"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                <DataGridCheckBoxColumn Header="Админ" Binding="{Binding IsAdmin}" Width="80"/>
                <DataGridCheckBoxColumn Header="Блок" Binding="{Binding IsBlocked}" Width="80"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
