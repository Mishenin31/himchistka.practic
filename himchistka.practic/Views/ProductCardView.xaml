<UserControl x:Class="himchistka.practic.Views.ProductCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Margin="0,0,0,12" Padding="12" Background="White" BorderBrush="#DEE3EE" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True" Width="126" Height="96" VerticalAlignment="Center">
                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="17" Foreground="#1D2E49"/>
                <TextBlock Text="{Binding Description}" Margin="0,8,0,8" TextWrapping="Wrap" Foreground="#4A5B79"/>
                <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" FontWeight="SemiBold" Foreground="#1F3A5F"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding Stock, StringFormat=Свободно слотов: {0}}" Foreground="#4A5B79" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <Button Content="В корзину"
                        Command="{Binding ElementName=Root, Path=AddToCartCommand}"
                        CommandParameter="{Binding}"
                        Padding="10,7"
                        Background="#1F3A5F"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
