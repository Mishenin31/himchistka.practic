<Page x:Class="himchistka.practic.Views.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:views="clr-namespace:himchistka.practic.Views"
      Title="CatalogPage">
    <Grid Background="#F4F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="76"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F3A5F" Padding="22,16" CornerRadius="0,0,18,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Crystal Clean" Foreground="White" FontWeight="Bold" FontSize="24"/>
                    <TextBlock Text="Профессиональная химчистка с доставкой" Foreground="#D6E4FF" FontSize="13"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding UserName}" Foreground="White" VerticalAlignment="Center" FontSize="16" Margin="0,0,14,0"/>
                <Button Grid.Column="2" Content="Выйти" Command="{Binding LogoutCommand}" Padding="14,7" Background="#E8EEF9" Foreground="#1F3A5F" BorderBrush="#D0DCF3" BorderThickness="1"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="20,16,20,8" Padding="16" Background="White" CornerRadius="14" BorderBrush="#E5E9F2" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="38"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Padding="12,0"
                         BorderBrush="#CDD6E8"
                         BorderThickness="1"
                         ToolTip="Введите название услуги или описание"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding CategoryOptions}"
                          SelectedItem="{Binding SelectedCategory}"
                          Height="38"
                          VerticalContentAlignment="Center"
                          FontSize="14"
                          Padding="8,0"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,8,20,12">
            <ItemsControl ItemsSource="{Binding FilteredProducts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ProductCardView AddToCartCommand="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Page}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#FFFFFF" Padding="14,12" BorderBrush="#E4E8F0" BorderThickness="1,1,1,0">
            <UniformGrid Columns="4" Rows="1">
                <Button Margin="6,0" Content="Заказы" Command="{Binding OpenOrderCommand}" Background="#ECF2FF" BorderThickness="0" FontWeight="SemiBold"/>
                <Button Margin="6,0" Content="Пользователи" Command="{Binding OpenUsersCommand}" Background="#ECF2FF" BorderThickness="0" FontWeight="SemiBold"/>
                <Button Margin="6,0" Content="Товары" Command="{Binding OpenProductsCommand}" Background="#ECF2FF" BorderThickness="0" FontWeight="SemiBold"/>
                <Button Margin="6,0" Content="Корзина" Command="{Binding OpenCartCommand}" Background="#1F3A5F" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
            </UniformGrid>
        </Border>
    </Grid>
</Page>
