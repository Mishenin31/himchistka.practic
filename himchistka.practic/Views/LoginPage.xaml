<Page x:Class="himchistka.practic.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage">
    <Grid Background="#F8F9F9">
        <Border Width="420" Padding="30" Background="White" CornerRadius="8" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Вход" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                <TextBlock Text="Логин"/>
                <TextBox Margin="0,6,0,12" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Пароль"/>
                <TextBox Margin="0,6,0,18" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Войти" Command="{Binding LoginCommand}" Height="36" Margin="0,0,0,10"/>
                <Button Content="Регистрация" Command="{Binding GoToRegisterCommand}" Height="32" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
