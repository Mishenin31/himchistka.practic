<Window x:Class="himchistka.practic.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Height="500"
        Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#FFF5F7FA">
    <Grid Margin="24">
        <Border Background="White" CornerRadius="14" Padding="24">
            <StackPanel>
                <TextBlock Text="Регистрация"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0 0 0 18"/>

                <TextBlock Text="ФИО"/>
                <TextBox x:Name="RegisterNameTextBox" Height="34" Margin="0 6 0 10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Логин"/>
                <TextBox x:Name="RegisterLoginTextBox" Height="34" Margin="0 6 0 10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="RegisterPasswordBox" Height="34" Margin="0 6 0 10"/>

                <TextBlock Text="Роль"/>
                <ComboBox x:Name="RegisterRoleComboBox" Height="34" Margin="0 6 0 18" SelectedIndex="0">
                    <ComboBoxItem Content="User"/>
                    <ComboBoxItem Content="Manager"/>
                    <ComboBoxItem Content="Admin"/>
                </ComboBox>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Назад" Width="120" Height="38" Margin="0 0 10 0" Click="BackButton_Click"/>
                    <Button Content="Зарегистрировать" Width="160" Height="38" Click="RegisterButton_Click"/>
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock" Margin="0 12 0 0" TextWrapping="Wrap" Foreground="DarkRed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
