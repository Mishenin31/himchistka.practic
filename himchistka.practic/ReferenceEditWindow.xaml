<Window x:Class="himchistka.practic.ReferenceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данные справочника"
        Height="300"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF2F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Тип" FontWeight="SemiBold"/>
        <TextBox x:Name="TypeTextBox" Grid.Row="1" Height="32" VerticalContentAlignment="Center" Margin="0 4 0 10"/>

        <TextBlock Grid.Row="2" Text="Наименование" FontWeight="SemiBold"/>
        <TextBox x:Name="NameTextBox" Grid.Row="3" Height="32" VerticalContentAlignment="Center" Margin="0 4 0 10"/>

        <TextBlock Grid.Row="4" Text="Значение" FontWeight="SemiBold"/>
        <TextBox x:Name="ValueTextBox" Grid.Row="5" Height="32" VerticalContentAlignment="Center" Margin="0 4 0 0"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <Button Width="110" Height="32" Content="Сохранить" Margin="0 0 8 0" Click="SaveButton_Click"/>
            <Button Width="90" Height="32" Content="Отмена" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
