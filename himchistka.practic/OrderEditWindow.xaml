<Window x:Class="himchistka.practic.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данные заказа"
        Height="420"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF2F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Клиент" FontWeight="SemiBold"/>
        <TextBox x:Name="ClientTextBox" Grid.Row="1" Height="32" VerticalContentAlignment="Center" Margin="0 4 0 12"/>

        <TextBlock Grid.Row="2" Text="Услуга" FontWeight="SemiBold"/>
        <TextBox x:Name="ServiceTextBox" Grid.Row="3" Height="32" VerticalContentAlignment="Center" Margin="0 4 0 12"/>

        <Grid Grid.Row="4" Margin="0 0 0 12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Дата приема" FontWeight="SemiBold"/>
                <DatePicker x:Name="DateReceivedPicker" Margin="0 4 0 0"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Сумма" FontWeight="SemiBold"/>
                <TextBox x:Name="TotalPriceTextBox" Height="32" VerticalContentAlignment="Center" Margin="0 4 0 0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="5">
            <TextBlock Text="Статус" FontWeight="SemiBold"/>
            <ComboBox x:Name="StatusComboBox" Height="32" Margin="0 4 0 0">
                <ComboBoxItem Content="Новый"/>
                <ComboBoxItem Content="В работе"/>
                <ComboBoxItem Content="Готов"/>
                <ComboBoxItem Content="Выдан"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <Button Width="110" Height="32" Content="Сохранить" Margin="0 0 8 0" Click="SaveButton_Click"/>
            <Button Width="90" Height="32" Content="Отмена" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
