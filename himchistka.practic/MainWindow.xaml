<Window x:Class="himchistka.practic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sobolhim Clean — Рабочее место" MinHeight="650" MinWidth="1100" Height="740" Width="1280"
        WindowStartupLocation="CenterScreen" Background="#FFF3F5F7">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" Margin="0 0 0 10" CornerRadius="12" Background="#FF243746">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="SOBOLHIM CLEAN" FontSize="12" FontWeight="Bold" Foreground="#FFF3C36A"/>
                    <TextBlock Text="Панель управления заказами химчистки" Margin="0 4 0 0" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Стиль интерфейса адаптирован под корпоративный сайт sobolhim.ru" Margin="0 6 0 0" Foreground="#FFD0D9E1"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Роль" Foreground="#FFD0D9E1" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="CurrentRoleTextBlock" Text="Не авторизован" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0 0 0 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Поиск и фильтры" Margin="0 0 8 0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="SearchTextBox" Margin="0 0 0 6" Height="30" VerticalContentAlignment="Center" ToolTip="Поиск по клиенту или услуге" TextChanged="SearchTextBox_TextChanged"/>
                    <UniformGrid Grid.Row="1" Rows="1" Columns="2">
                        <ComboBox x:Name="StatusFilterComboBox" Margin="0 0 6 0" Height="30" SelectionChanged="StatusFilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                            <ComboBoxItem Content="Новый"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="Готов"/>
                            <ComboBoxItem Content="Выдан"/>
                        </ComboBox>
                        <ComboBox x:Name="SortComboBox" Margin="6 0 0 0" Height="30" SelectionChanged="SortComboBox_SelectionChanged">
                            <ComboBoxItem Content="По дате (новые сначала)" IsSelected="True"/>
                            <ComboBoxItem Content="По цене (возрастание)"/>
                            <ComboBoxItem Content="По цене (убывание)"/>
                            <ComboBoxItem Content="По клиенту (А-Я)"/>
                        </ComboBox>
                    </UniformGrid>
                </Grid>
            </GroupBox>

            <Border Grid.Column="1" Margin="0 0 8 0" Background="White" CornerRadius="8" BorderBrush="#FFDCE2E8" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="Активных заказов" Foreground="#FF5C6670"/>
                    <TextBlock Text="148" FontSize="24" FontWeight="SemiBold" Foreground="#FF223746"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="0 0 8 0" Background="White" CornerRadius="8" BorderBrush="#FFDCE2E8" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="Средний чек" Foreground="#FF5C6670"/>
                    <TextBlock Text="3 540 ₽" FontSize="24" FontWeight="SemiBold" Foreground="#FF223746"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center">
                <Button x:Name="AddOrderButton" Content="Добавить" Height="30" Margin="0 0 0 6" Click="AddOrderButton_Click"/>
                <Button x:Name="EditOrderButton" Content="Редактировать" Height="30" Margin="0 0 0 6" Click="EditOrderButton_Click"/>
                <Button x:Name="DeleteOrderButton" Content="Удалить" Height="30" Click="DeleteOrderButton_Click"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2" x:Name="TablesTabControl">
            <TabItem Header="Общая таблица заказов" x:Name="OrdersTab">
                <DataGrid x:Name="OrdersDataGrid" AutoGenerateColumns="False" Margin="0 8 0 0" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Клиент" Binding="{Binding ClientFullName}" Width="*"/>
                        <DataGridTextColumn Header="Услуга" Binding="{Binding ServiceName}" Width="*"/>
                        <DataGridTextColumn Header="Дата приема" Binding="{Binding DateReceived, StringFormat=dd.MM.yyyy}" Width="140"/>
                        <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalPrice, StringFormat=N0}" Width="120"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Таблица клиентов" x:Name="ClientsTab">
                <DataGrid x:Name="ClientsDataGrid" AutoGenerateColumns="False" Margin="0 8 0 0" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="200"/>
                        <DataGridTextColumn Header="Лояльность" Binding="{Binding LoyaltyLevel}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="3" Margin="0 10 0 0">
            <TextBlock x:Name="StatusMessageTextBlock" Text="Добро пожаловать в рабочую панель."/>
        </StatusBar>
    </Grid>
</Window>
