<Window x:Class="himchistka.practic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CleanersDB — Панель"
        Height="760"
        Width="1280"
        MinHeight="680"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF2F5F9">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF243746"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFF3C36A"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="16" Background="{StaticResource PrimaryBrush}" Padding="20" Margin="0 0 0 12">
            <DockPanel>
                <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                    <TextBlock Text="CleanersDB" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Каталог, корзина, заказы и админ-панель" Foreground="#FFD4E0EA" Margin="0 4 0 0"/>
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="#1EFFFFFF" CornerRadius="10" Padding="12 6">
                    <TextBlock x:Name="CurrentRoleTextBlock" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="12" Margin="0 0 0 12">
            <StackPanel Orientation="Horizontal">
                <Button Content="Пользователи" Click="UsersSectionButton_Click"/>
                <Button Content="Заказы" Click="OrdersSectionButton_Click"/>
                <Button Content="Товары" Click="ProductsSectionButton_Click" Margin="0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="12" Margin="0 0 0 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchTextBox" Grid.Column="0" Margin="0 0 8 0" Height="32" VerticalContentAlignment="Center" TextChanged="SearchTextBox_TextChanged"/>
                <ComboBox x:Name="StatusFilterComboBox" Grid.Column="1" Margin="0 0 8 0" Height="32" SelectionChanged="StatusFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                    <ComboBoxItem Content="Новый"/>
                    <ComboBoxItem Content="В работе"/>
                    <ComboBoxItem Content="Готов"/>
                    <ComboBoxItem Content="Выдан"/>
                </ComboBox>
                <ComboBox x:Name="SortComboBox" Grid.Column="2" Height="32" SelectionChanged="SortComboBox_SelectionChanged">
                    <ComboBoxItem Content="По дате (новые сначала)" IsSelected="True"/>
                    <ComboBoxItem Content="По цене (возрастание)"/>
                    <ComboBoxItem Content="По цене (убывание)"/>
                    <ComboBoxItem Content="По клиенту (А-Я)"/>
                </ComboBox>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10 0 0 0">
                    <Button x:Name="AddToCartButton" Content="В корзину" Click="AddToCartButton_Click"/>
                    <Button x:Name="CreateOrderFromCartButton" Content="Оформить" Click="CreateOrderFromCartButton_Click"/>
                    <Button x:Name="AddOrderButton" Content="+ Заказ" Click="AddOrderButton_Click"/>
                    <Button x:Name="EditOrderButton" Content="Изм." Click="EditOrderButton_Click"/>
                    <Button x:Name="DeleteOrderButton" Content="Удалить" Margin="0" Click="DeleteOrderButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="10">
            <TabControl x:Name="TablesTabControl" SelectionChanged="TablesTabControl_SelectionChanged">
                <TabItem Header="Заказы" x:Name="OrdersTab">
                    <ListView x:Name="OrdersDataGrid">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Клиент" Width="220" DisplayMemberBinding="{Binding ClientFullName}"/>
                                <GridViewColumn Header="Услуги" Width="230" DisplayMemberBinding="{Binding ServiceName}"/>
                                <GridViewColumn Header="Дата" Width="160" DisplayMemberBinding="{Binding DateReceived, StringFormat=dd.MM.yyyy HH:mm}"/>
                                <GridViewColumn Header="Сумма" Width="120" DisplayMemberBinding="{Binding TotalPrice, StringFormat=N0}"/>
                                <GridViewColumn Header="Статус" Width="120" DisplayMemberBinding="{Binding Status}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="Товары" x:Name="ServicesCatalogTab">
                    <ListView x:Name="ServicesCatalogDataGrid">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Название" Width="260" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Категория" Width="180" DisplayMemberBinding="{Binding Category}"/>
                                <GridViewColumn Header="Срок" Width="140" DisplayMemberBinding="{Binding Duration}"/>
                                <GridViewColumn Header="Цена" Width="120" DisplayMemberBinding="{Binding BasePrice, StringFormat=N0}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="Корзина" x:Name="CartTab" Visibility="Collapsed">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                            <Button x:Name="RemoveFromCartButton" Content="Удалить позицию" Click="RemoveFromCartButton_Click"/>
                            <Button x:Name="ClearCartButton" Content="Очистить корзину" Margin="0" Click="ClearCartButton_Click"/>
                        </StackPanel>
                        <ListView x:Name="CartDataGrid">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                    <GridViewColumn Header="Услуга" Width="250" DisplayMemberBinding="{Binding ServiceName}"/>
                                    <GridViewColumn Header="Цена" Width="120" DisplayMemberBinding="{Binding UnitPrice, StringFormat=N0}"/>
                                    <GridViewColumn Header="Кол-во" Width="90" DisplayMemberBinding="{Binding Quantity}"/>
                                    <GridViewColumn Header="Сумма" Width="120" DisplayMemberBinding="{Binding TotalPrice, StringFormat=N0}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Пользователи" x:Name="UsersTab">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                            <Button Content="Добавить" Margin="0 0 8 0" Click="AddUserButton_Click"/>
                            <Button Content="Сделать User" Margin="0 0 8 0" Click="MakeUserRoleButton_Click"/>
                            <Button Content="Удалить" Margin="0" Click="DeleteUserButton_Click"/>
                        </StackPanel>
                        <ListView x:Name="UsersDataGrid">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                    <GridViewColumn Header="ФИО" Width="280" DisplayMemberBinding="{Binding FullName}"/>
                                    <GridViewColumn Header="Логин" Width="180" DisplayMemberBinding="{Binding Login}"/>
                                    <GridViewColumn Header="Роль" Width="140" DisplayMemberBinding="{Binding Role}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Справочники" x:Name="ReferencesTab" Visibility="Collapsed">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                            <Button Content="Добавить" Margin="0 0 8 0" Click="AddReferenceButton_Click"/>
                            <Button Content="Изменить" Margin="0 0 8 0" Click="EditReferenceButton_Click"/>
                            <Button Content="Удалить" Margin="0" Click="DeleteReferenceButton_Click"/>
                        </StackPanel>
                        <ListView x:Name="ReferencesDataGrid">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                    <GridViewColumn Header="Тип" Width="140" DisplayMemberBinding="{Binding Type}"/>
                                    <GridViewColumn Header="Наименование" Width="300" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Значение" Width="180" DisplayMemberBinding="{Binding Value}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="4" Background="White" CornerRadius="10" Padding="12" Margin="0 12 0 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Активных заказов:" VerticalAlignment="Center"/>
                <TextBlock x:Name="ActiveOrdersTextBlock" Grid.Column="1" Margin="6 0 16 0" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock x:Name="StatusMessageTextBlock" Grid.Column="2" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>
