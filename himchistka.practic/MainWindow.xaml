<Window x:Class="himchistka.practic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sobolhim Clean — Рабочее место" MinHeight="650" MinWidth="1100" Height="740" Width="1280"
        WindowStartupLocation="CenterScreen" Background="#FFF3F5F7">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" Margin="0 0 0 10" CornerRadius="12" Background="#FF243746">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="SOBOLHIM CLEAN" FontSize="12" FontWeight="Bold" Foreground="#FFF3C36A"/>
                    <TextBlock Text="Панель управления заказами химчистки" Margin="0 4 0 0" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Стиль интерфейса адаптирован под корпоративный сайт sobolhim.ru" Margin="0 6 0 0" Foreground="#FFD0D9E1"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Роль" Foreground="#FFD0D9E1" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="CurrentRoleTextBlock" Text="Не авторизован" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0 0 0 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Поиск и фильтры" Margin="0 0 8 0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="SearchTextBox" Margin="0 0 0 6" Height="30" VerticalContentAlignment="Center" ToolTip="Поиск по клиенту или услуге" TextChanged="SearchTextBox_TextChanged"/>
                    <UniformGrid Grid.Row="1" Rows="1" Columns="2">
                        <ComboBox x:Name="StatusFilterComboBox" Margin="0 0 6 0" Height="30" SelectionChanged="StatusFilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                            <ComboBoxItem Content="Новый"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="Готов"/>
                            <ComboBoxItem Content="Выдан"/>
                        </ComboBox>
                        <ComboBox x:Name="SortComboBox" Margin="6 0 0 0" Height="30" SelectionChanged="SortComboBox_SelectionChanged">
                            <ComboBoxItem Content="По дате (новые сначала)" IsSelected="True"/>
                            <ComboBoxItem Content="По цене (возрастание)"/>
                            <ComboBoxItem Content="По цене (убывание)"/>
                            <ComboBoxItem Content="По клиенту (А-Я)"/>
                        </ComboBox>
                    </UniformGrid>
                </Grid>
            </GroupBox>

            <Border Grid.Column="1" Margin="0 0 8 0" Background="White" CornerRadius="8" BorderBrush="#FFDCE2E8" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="Активных заказов" Foreground="#FF5C6670"/>
                    <TextBlock x:Name="ActiveOrdersTextBlock" Text="0" FontSize="24" FontWeight="SemiBold" Foreground="#FF223746"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="0 0 8 0" Background="White" CornerRadius="8" BorderBrush="#FFDCE2E8" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="Средний чек" Foreground="#FF5C6670"/>
                    <TextBlock x:Name="AverageCheckTextBlock" Text="0 ₽" FontSize="24" FontWeight="SemiBold" Foreground="#FF223746"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 6">
                    <Button x:Name="PreviousTabButton" Content="◀" Width="32" Height="30" Margin="0 0 6 0" Click="PreviousTabButton_Click" ToolTip="Предыдущая вкладка"/>
                    <Button x:Name="NextTabButton" Content="▶" Width="32" Height="30" Click="NextTabButton_Click" ToolTip="Следующая вкладка"/>
                </StackPanel>
                <Button x:Name="AddOrderButton" Content="Добавить" Height="30" Margin="0 0 0 6" Click="AddOrderButton_Click"/>
                <Button x:Name="EditOrderButton" Content="Редактировать" Height="30" Margin="0 0 0 6" Click="EditOrderButton_Click"/>
                <Button x:Name="DeleteOrderButton" Content="Удалить" Height="30" Click="DeleteOrderButton_Click"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2" x:Name="TablesTabControl" SelectionChanged="TablesTabControl_SelectionChanged">
            <TabItem Header="Общая таблица заказов" x:Name="OrdersTab">
                <DataGrid x:Name="OrdersDataGrid" AutoGenerateColumns="False" Margin="0 8 0 0" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Клиент" Binding="{Binding ClientFullName}" Width="*"/>
                        <DataGridTextColumn Header="Услуга" Binding="{Binding ServiceName}" Width="*"/>
                        <DataGridTextColumn Header="Дата приема" Binding="{Binding DateReceived, StringFormat=dd.MM.yyyy}" Width="140"/>
                        <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalPrice, StringFormat=N0}" Width="120"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Таблица клиентов" x:Name="ClientsTab">
                <DataGrid x:Name="ClientsDataGrid" AutoGenerateColumns="False" Margin="0 8 0 0" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="200"/>
                        <DataGridTextColumn Header="Лояльность" Binding="{Binding LoyaltyLevel}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Каталог услуг" x:Name="ServicesCatalogTab">
                <DataGrid x:Name="ServicesCatalogDataGrid" AutoGenerateColumns="False" Margin="0 8 0 0" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Услуга" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="220"/>
                        <DataGridTextColumn Header="Срок выполнения" Binding="{Binding Duration}" Width="170"/>
                        <DataGridTextColumn Header="Базовая цена" Binding="{Binding BasePrice, StringFormat=N0}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Статистика" x:Name="StatisticsTab">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0 0 8 0">
                        <TextBlock Text="Заказы по статусам" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 8"/>
                        <TextBlock x:Name="NewOrdersCountTextBlock" Margin="0 0 0 6"/>
                        <TextBlock x:Name="InProgressOrdersCountTextBlock" Margin="0 0 0 6"/>
                        <TextBlock x:Name="ReadyOrdersCountTextBlock" Margin="0 0 0 6"/>
                        <TextBlock x:Name="DeliveredOrdersCountTextBlock" Margin="0 0 0 6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8 0 0 0">
                        <TextBlock Text="Клиенты" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 8"/>
                        <TextBlock x:Name="ClientsCountTextBlock" Margin="0 0 0 6"/>
                        <TextBlock x:Name="TopClientTextBlock" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Личный кабинет" x:Name="ProfileTab">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" BorderBrush="#FFDCE2E8" BorderThickness="1" Padding="14" Margin="0 0 10 0">
                        <StackPanel>
                            <TextBlock Text="Профиль сотрудника" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 12"/>
                            <TextBlock Text="ФИО"/>
                            <TextBox x:Name="ProfileFullNameTextBox" Height="34" Margin="0 6 0 10" VerticalContentAlignment="Center"/>
                            <TextBlock Text="Логин"/>
                            <TextBox x:Name="ProfileLoginTextBox" Height="34" Margin="0 6 0 10" VerticalContentAlignment="Center" IsReadOnly="True" Background="#FFF4F4F4"/>
                            <TextBlock Text="Роль"/>
                            <TextBox x:Name="ProfileRoleTextBox" Height="34" Margin="0 6 0 10" VerticalContentAlignment="Center" IsReadOnly="True" Background="#FFF4F4F4"/>
                            <TextBlock Text="Новый пароль"/>
                            <PasswordBox x:Name="ProfilePasswordBox" Height="34" Margin="0 6 0 14"/>
                            <Button x:Name="SaveProfileButton" Content="Сохранить изменения" Height="36" Click="SaveProfileButton_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#FF243746" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Личный кабинет" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="В этом разделе можно обновить личные данные сотрудника и пароль для входа." Margin="0 10 0 14" TextWrapping="Wrap" Foreground="#FFD6DEE6"/>
                            <TextBlock x:Name="ProfileLastUpdateTextBlock" Foreground="#FFF3C36A" Margin="0 0 0 12"/>
                            <Border Background="#1EFFFFFF" CornerRadius="8" Padding="10" Margin="0 0 0 8">
                                <TextBlock x:Name="ProfileSummaryTextBlock" TextWrapping="Wrap" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="3" Margin="0 10 0 0">
            <TextBlock x:Name="StatusMessageTextBlock" Text="Добро пожаловать в рабочую панель."/>
        </StatusBar>
    </Grid>
</Window>
