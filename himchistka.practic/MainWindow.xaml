<Window x:Class="himchistka.practic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог"
        Height="760"
        Width="1200"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFEFEFEF"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ProductListStyle" TargetType="ListViewItem">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="Black" BorderThickness="6" Margin="12" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="Black" BorderThickness="2" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="logo" FontSize="36" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="каталог" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <Button Content="выход" Padding="14,2" FontSize="26" Margin="0 0 0 6" />
                        <TextBlock x:Name="CurrentRoleTextBlock" Text="имя" FontSize="30" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="Black" BorderThickness="2" Padding="8">
                    <TextBlock Text="товар цена" FontSize="38" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="2" Padding="8" Margin="-2,0,-2,0">
                    <TextBlock Text="информация о товаре" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="2" BorderBrush="Black" BorderThickness="2" Padding="8">
                    <TextBlock Text="в корзину" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <TabControl x:Name="TablesTabControl" SelectionChanged="TablesTabControl_SelectionChanged" BorderThickness="0" Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="Заказы" x:Name="OrdersTab">
                        <ListView x:Name="OrdersDataGrid" FontSize="30" BorderThickness="2" BorderBrush="Black">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="80" DisplayMemberBinding="{Binding Id}"/>
                                    <GridViewColumn Header="Клиент" Width="260" DisplayMemberBinding="{Binding ClientFullName}"/>
                                    <GridViewColumn Header="Услуги" Width="250" DisplayMemberBinding="{Binding ServiceName}"/>
                                    <GridViewColumn Header="Дата" Width="180" DisplayMemberBinding="{Binding DateReceived, StringFormat=dd.MM.yyyy}"/>
                                    <GridViewColumn Header="Сумма" Width="120" DisplayMemberBinding="{Binding TotalPrice}"/>
                                    <GridViewColumn Header="Статус" Width="140" DisplayMemberBinding="{Binding Status}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>

                    <TabItem Header="Товары" x:Name="ServicesCatalogTab">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SearchTextBox" Grid.Column="0" Margin="0,0,8,0" Height="44" VerticalContentAlignment="Center" FontSize="22" TextChanged="SearchTextBox_TextChanged"/>
                                <ComboBox x:Name="StatusFilterComboBox" Grid.Column="1" Margin="0,0,8,0" Height="44" FontSize="22" SelectionChanged="StatusFilterComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                                    <ComboBoxItem Content="Новый"/>
                                    <ComboBoxItem Content="В работе"/>
                                    <ComboBoxItem Content="Готов"/>
                                    <ComboBoxItem Content="Выдан"/>
                                </ComboBox>
                                <ComboBox x:Name="SortComboBox" Grid.Column="2" Height="44" FontSize="22" SelectionChanged="SortComboBox_SelectionChanged">
                                    <ComboBoxItem Content="По дате (новые сначала)" IsSelected="True"/>
                                    <ComboBoxItem Content="По цене (возрастание)"/>
                                    <ComboBoxItem Content="По цене (убывание)"/>
                                    <ComboBoxItem Content="По клиенту (А-Я)"/>
                                </ComboBox>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0,0,0">
                                    <Button x:Name="AddToCartButton" Content="В корзину" Click="AddToCartButton_Click" FontSize="22" Height="44"/>
                                    <Button x:Name="CreateOrderFromCartButton" Content="Оформить" Click="CreateOrderFromCartButton_Click" FontSize="22" Height="44"/>
                                </StackPanel>
                            </Grid>

                            <ListView x:Name="ServicesCatalogDataGrid" Grid.Row="1" BorderThickness="2" BorderBrush="Black" ItemContainerStyle="{StaticResource ProductListStyle}" FontSize="38">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="товар" Width="180" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="информация о товаре" Width="620" DisplayMemberBinding="{Binding Category}"/>
                                        <GridViewColumn Header="в корзину" Width="220" DisplayMemberBinding="{Binding BasePrice, StringFormat=N0}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Корзина" x:Name="CartTab">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                                <Button x:Name="RemoveFromCartButton" Content="Удалить позицию" Click="RemoveFromCartButton_Click" FontSize="22" Height="44"/>
                                <Button x:Name="ClearCartButton" Content="Очистить корзину" Margin="0" Click="ClearCartButton_Click" FontSize="22" Height="44"/>
                            </StackPanel>
                            <ListView x:Name="CartDataGrid">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Услуга" Width="250" DisplayMemberBinding="{Binding ServiceName}"/>
                                        <GridViewColumn Header="Цена" Width="120" DisplayMemberBinding="{Binding UnitPrice, StringFormat=N0}"/>
                                        <GridViewColumn Header="Кол-во" Width="90" DisplayMemberBinding="{Binding Quantity}"/>
                                        <GridViewColumn Header="Сумма" Width="120" DisplayMemberBinding="{Binding TotalPrice, StringFormat=N0}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Пользователи" x:Name="UsersTab">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                                <Button Content="Добавить" Margin="0 0 8 0" Click="AddUserButton_Click" FontSize="22" Height="44"/>
                                <Button Content="Сделать User" Margin="0 0 8 0" Click="MakeUserRoleButton_Click" FontSize="22" Height="44"/>
                                <Button Content="Удалить" Margin="0" Click="DeleteUserButton_Click" FontSize="22" Height="44"/>
                            </StackPanel>
                            <ListView x:Name="UsersDataGrid">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="ФИО" Width="280" DisplayMemberBinding="{Binding FullName}"/>
                                        <GridViewColumn Header="Логин" Width="180" DisplayMemberBinding="{Binding Login}"/>
                                        <GridViewColumn Header="Роль" Width="140" DisplayMemberBinding="{Binding Role}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Справочники" x:Name="ReferencesTab" Visibility="Collapsed">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                                <Button Content="Добавить" Margin="0 0 8 0" Click="AddReferenceButton_Click" FontSize="22" Height="44"/>
                                <Button Content="Изменить" Margin="0 0 8 0" Click="EditReferenceButton_Click" FontSize="22" Height="44"/>
                                <Button Content="Удалить" Margin="0" Click="DeleteReferenceButton_Click" FontSize="22" Height="44"/>
                            </StackPanel>
                            <ListView x:Name="ReferencesDataGrid">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Тип" Width="140" DisplayMemberBinding="{Binding Type}"/>
                                        <GridViewColumn Header="Наименование" Width="300" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="Значение" Width="180" DisplayMemberBinding="{Binding Value}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Grid>

            <Border Grid.Row="3" BorderBrush="Black" BorderThickness="2" Padding="8" Margin="0,8,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Активных заказов:" FontSize="22" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActiveOrdersTextBlock" Grid.Column="1" FontSize="22" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusMessageTextBlock" Grid.Column="2" FontSize="20" Margin="20,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="4" Columns="4" Margin="0,4,0,0">
                <Button Content="заказ" Click="OrdersSectionButton_Click" Margin="0"/>
                <Button Content="пользователь" Click="UsersSectionButton_Click" Margin="0"/>
                <Button Content="товары" Click="ProductsSectionButton_Click" Margin="0"/>
                <Button Content="корзина" Margin="0" Click="CartSectionButton_Click"/>
            </UniformGrid>

            <StackPanel Visibility="Collapsed">
                <Button x:Name="AddOrderButton" Content="+ Заказ" Click="AddOrderButton_Click"/>
                <Button x:Name="EditOrderButton" Content="Изм." Click="EditOrderButton_Click"/>
                <Button x:Name="DeleteOrderButton" Content="Удалить" Click="DeleteOrderButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
