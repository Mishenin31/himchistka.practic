<Window x:Class="himchistka.practic.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sobolhim Clean — Авторизация"
        Height="680"
        Width="1080"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8F8">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="18" CornerRadius="16" Background="#FF243746">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="SOBOLHIM CLEAN"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#FFF3C36A"/>
                    <TextBlock Text="Премиальная химчистка и прачечная"
                               Margin="0 14 0 0"
                               FontSize="34"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Foreground="White"/>
                    <TextBlock Text="Управляйте заказами, клиентами и статусами работ в едином рабочем окне."
                               Margin="0 14 0 0"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Foreground="#FFD6DEE6"/>
                </StackPanel>

                <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0 24 0 0">
                    <Border Margin="0 0 12 0" CornerRadius="12" Background="#1EFFFFFF" Padding="12">
                        <StackPanel>
                            <TextBlock Text="24/7" FontSize="26" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="прием заявок" Foreground="#FFC6D0DA"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="0 0 12 0" CornerRadius="12" Background="#1EFFFFFF" Padding="12">
                        <StackPanel>
                            <TextBlock Text="8+" FontSize="26" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="лет на рынке" Foreground="#FFC6D0DA"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="12" Background="#1EFFFFFF" Padding="12">
                        <StackPanel>
                            <TextBlock Text="1200" FontSize="26" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="клиентов / месяц" Foreground="#FFC6D0DA"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Grid.Row="2"
                           Text="Пожалуйста, авторизуйтесь для входа в систему."
                           FontSize="14"
                           Foreground="#FFE6EDF4"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="18 18 18 18" CornerRadius="16" Background="White" Padding="30">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Вход в аккаунт" FontSize="30" FontWeight="SemiBold" Foreground="#FF1F2B36"/>
                    <TextBlock Text="Используйте логин и пароль сотрудника." Margin="0 8 0 24" Foreground="#FF5D6A74"/>

                    <TextBlock Text="Логин"/>
                    <TextBox x:Name="LoginTextBox" Height="36" Margin="0 6 0 14" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Пароль"/>
                    <PasswordBox x:Name="PasswordBox" Height="36" Margin="0 6 0 18"/>

                    <Button x:Name="SignInButton"
                            Content="Войти в систему"
                            Height="40"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="#FF243746"
                            Foreground="White"
                            Click="SignInButton_Click"/>

                    <Expander Header="Регистрация нового сотрудника" Margin="0 24 0 0">
                        <StackPanel Margin="0 12 0 0">
                            <TextBox x:Name="RegisterNameTextBox" Height="34" Margin="0 0 0 8" VerticalContentAlignment="Center" ToolTip="ФИО"/>
                            <TextBox x:Name="RegisterLoginTextBox" Height="34" Margin="0 0 0 8" VerticalContentAlignment="Center" ToolTip="Логин"/>
                            <PasswordBox x:Name="RegisterPasswordBox" Height="34" Margin="0 0 0 8" ToolTip="Пароль"/>
                            <ComboBox x:Name="RegisterRoleComboBox" Height="34" Margin="0 0 0 8" SelectedIndex="0">
                                <ComboBoxItem Content="User"/>
                                <ComboBoxItem Content="Manager"/>
                                <ComboBoxItem Content="Admin"/>
                            </ComboBox>
                            <Button x:Name="RegisterButton" Content="Зарегистрировать" Height="36" Click="RegisterButton_Click"/>
                        </StackPanel>
                    </Expander>

                    <TextBlock x:Name="StatusTextBlock" Margin="0 14 0 0" Foreground="#FF8A2630" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
