<Window x:Class="himchistka.practic.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход"
        Height="420"
        Width="720"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F7FA">
    <Grid Margin="24">
        <Border Background="White" CornerRadius="14" Padding="24">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Вход"
                           FontSize="34"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 24"/>

                <Button Content="Авторизация"
                        Height="44"
                        Margin="0 0 0 12"
                        FontSize="16"
                        Click="OpenAuthButton_Click"/>

                <Button Content="Регистрация"
                        Height="44"
                        FontSize="16"
                        Click="OpenRegisterButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
